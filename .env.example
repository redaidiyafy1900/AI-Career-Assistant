# ============================================
#  智能职业发展助手 - 环境配置模板
# ============================================
#  使用方法：复制此文件为 .env 并填写实际值
#    copy .env.example .env
# ============================================

# ---- 火山方舟（豆包）API 配置（当前使用）----
# 用于：模拟面试、岗位匹配、简历优化、简历解析
# 获取地址：https://console.volcengine.com/ark/management/endpoint

INTERVIEW_DOBAO_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
INTERVIEW_DOBAO_API_KEY=your_volcano_api_key_here
INTERVIEW_DOBAO_MODEL=your_model_endpoint_id

DOUBAO_API_KEY=your_volcano_api_key_here
DOUBAO_MODEL=your_model_endpoint_id

# ---- FastGPT API 配置（原始实现，可选）----
# 面试功能最初基于 FastGPT 实现，如需切换回 FastGPT，取消以下注释并填入配置：
#
# FASTGPT_BASE_URL=http://your-fastgpt-server:3000
# INTERVIEW_FASTGPT_API_KEY=your_fastgpt_api_key
# INTERVIEW_FASTGPT_APP_ID=your_fastgpt_app_id
#
# 注意：FastGPT 为原始 AI 面试方案，当前版本默认使用火山方舟 API 作为替代。

# ---- SMTP 邮件配置（自动投递功能，可选）----
# QQ邮箱示例：

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_EMAIL=your_email@qq.com
SMTP_PASSWORD=your_smtp_auth_code

# ---- 服务器配置 ----

PORT=3002
MAX_FILE_SIZE=5242880
